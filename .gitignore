# macOS / 编辑器
.DS_Store
.idea/
.vscode/

# Go 本地构建产物
bin/
dist/bin/

# Wails / 桌面端本地产物（bin/ 已被上面兜住，这里只管 app bundle 和生成物）
/factory-desktop
cmd/tshoot-desktop/build/bin/
# web/wailsjs/go/ 入库(由 wails generate module 生成,跟 Go App 方法同步更新,
# 入库省去 clone 后首次 build 还要先跑生成;改了 Go binding 后跑 make wails-gen 刷新)

# 本地 demo 产物(非 templates/ 下的真实模板)；锚到仓库根，不误杀 internal/webui/dist/ 等。
# `/dist*/` 同时盖 `/dist/`(默认 openclaw 产物)+ `/dist-claude-code/` `/dist-cursor/` `/dist-codex/`
# (多 target gen 时各 target 会产到 `<dist>-<target>/`),全部不入库。
/dist*/
# internal/webui/dist/ 是 npm build 后 cp 进来的 embed 目标，也不入库；
# 没执行 cp 时 webui.Distribution() 会回退到 placeholder/（见 internal/webui/webui.go）
/internal/webui/dist/

# Web 构建与依赖
web/dist/
web/node_modules/
# vitest / vite 偶尔在仓库根起 cache(本来不该,但 cwd 切换时会),跟 web/node_modules/ 一样不入库
/node_modules/

# 本机凭证草稿(init wizard / install.sh 自动生成)
scripts/.env
.tshoot/

# 本机工具链个人配置(不应入库)
.claude/settings.local.json
.opencode/node_modules/
.opencode/bun.lock

# Python bytecode caches(timeline.py 等运行后产物,不该 track)
__pycache__/
*.pyc

# Editor swap files (vim/emacs)
*.swp
*.swo
.*.swp
.*.swo
