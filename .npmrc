# 仓库根 .npmrc —— 防御性设置:本仓库不是 Node 项目,所有 web 资产都在 web/ 子目录。
#
# 历史问题:vitest / vite 偶尔在 cwd 错误时(IDE / claude session 切换 cwd)在仓库根创建
# node_modules/.vite/vitest/...,污染 git status + 撑大 .gitignore。
#
# package-lock=false：不允许在 cwd 自动写 lock 文件。
# ignore-scripts=true：不允许在 cwd 触发 install 脚本(防御性,因为这里压根不该 npm install)。
# 真正的 npm 工作目录是 web/,那里有自己的 package.json + package-lock.json,本文件不影响。
package-lock=false
ignore-scripts=true
