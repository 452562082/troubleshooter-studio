#!/usr/bin/env bash
# {{ .System.Name }} 排障机器人 — Claude Code subagent 一键安装
# 由 troubleshooter-studio 生成
#
# 安装位置(用户级,所有项目共享):
#   ~/.claude/agents/<name>.md      —— subagent 定义
#   ~/.claude/skills/<name>/        —— 该机器人专属 skills(命名空间隔离防覆盖其他 agent)
#   ~/.claude/scripts/<name>/       —— 辅助脚本(同上隔离)
#
# 用法:
#   bash install.sh                 # 装到 ~/.claude/agents/
#
# 装完后任意目录跑 `claude`,主对话里 @<name> 即可调用本 subagent。
set -euo pipefail

SRC="$(cd "$(dirname "$0")" && pwd)"
TS="$(date +%Y%m%d-%H%M%S)"

DST_HOME="${HOME}/.claude"
mkdir -p "$DST_HOME/agents" "$DST_HOME/skills" "$DST_HOME/scripts"

# 取 agents/ 下的第一个 .md(只生成一个) → name = 文件名(不含扩展)
AGENT_FILE=$(ls "$SRC/agents"/*.md 2>/dev/null | head -n1)
if [ -z "$AGENT_FILE" ]; then
  echo "错误:产物里没有 agents/*.md" >&2
  exit 1
fi
NAME="$(basename "$AGENT_FILE" .md)"

echo "→ 安装 Claude Code subagent: $NAME"
echo "→ 用户级目录:$DST_HOME"

# 1. agent 定义文件 —— 已存在则备份
DST_AGENT="$DST_HOME/agents/$NAME.md"
if [ -f "$DST_AGENT" ]; then
  cp "$DST_AGENT" "$DST_AGENT.bak.$TS"
  echo "  · 已备份原 agent → $DST_AGENT.bak.$TS"
fi
cp "$AGENT_FILE" "$DST_AGENT"
echo "  · agents/$NAME.md"

# 2. skills/ 装到 ~/.claude/skills/<NAME>/(命名空间防撞)
DST_SKILLS="$DST_HOME/skills/$NAME"
rm -rf "$DST_SKILLS"
mkdir -p "$DST_SKILLS"
if [ -d "$SRC/skills" ]; then
  cp -R "$SRC/skills/"* "$DST_SKILLS/" 2>/dev/null || true
  echo "  · skills/$NAME/"
fi

# 3. scripts/ 装到 ~/.claude/scripts/<NAME>/
DST_SCRIPTS="$DST_HOME/scripts/$NAME"
if [ -d "$SRC/scripts" ]; then
  rm -rf "$DST_SCRIPTS"
  mkdir -p "$DST_SCRIPTS"
  cp -R "$SRC/scripts/"* "$DST_SCRIPTS/" 2>/dev/null || true
  echo "  · scripts/$NAME/"
fi

echo ""
echo "✓ 安装完成。"
echo ""
echo "── 下一步:首次对话 ───────────────────────────────────────────"
echo "  1. 任意目录启动 Claude Code:"
echo "       claude"
echo "  2. 主对话里委派给本 subagent:"
{{- $firstEnv := "" -}}
{{- range $i, $e := .Environments -}}{{- if eq $i 0 -}}{{- $firstEnv = $e.ID -}}{{- end -}}{{- end -}}
{{- $prodEnv := $firstEnv -}}
{{- range .Environments -}}{{- if .IsProd -}}{{- $prodEnv = .ID -}}{{- end -}}{{- end }}
{{- $firstRepo := "" -}}
{{- range $i, $r := .Repos -}}{{- if eq $i 0 -}}{{- $firstRepo = $r.Name -}}{{- end -}}{{- end }}
echo "       @$NAME {{$firstEnv}} 环境 {{if $firstRepo}}{{$firstRepo}}{{else}}<service>{{end}} 接口 500 突增"
echo "       @$NAME {{$prodEnv}} 订单 #20250417XXX 用户说付了钱但没发货"
echo "       @$NAME {{$firstEnv}} 的 {{if $firstRepo}}{{$firstRepo}}{{else}}<service>{{end}} 为什么连不上下游?"
