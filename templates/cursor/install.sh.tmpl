#!/usr/bin/env bash
# {{ .System.Name }} 排障机器人 — Cursor Custom Agent 一键安装
# 由 troubleshooter-studio 生成
#
# 安装位置(用户级,所有项目共享):
#   ~/.cursor/agents/<name>.md      —— Custom Agent 定义
#   ~/.cursor/skills/<name>/        —— 该机器人专属 skills(命名空间隔离)
#   ~/.cursor/scripts/<name>/       —— 辅助脚本
#
# 用法:
#   bash install.sh                 # 装到 ~/.cursor/agents/
#
# 装完后任意 Cursor 项目里 → AI 侧栏选 Custom Agent → @<name>。
set -euo pipefail

SRC="$(cd "$(dirname "$0")" && pwd)"
TS="$(date +%Y%m%d-%H%M%S)"

DST_HOME="${HOME}/.cursor"
mkdir -p "$DST_HOME/agents" "$DST_HOME/skills" "$DST_HOME/scripts"

AGENT_FILE=$(ls "$SRC/agents"/*.md 2>/dev/null | head -n1)
if [ -z "$AGENT_FILE" ]; then
  echo "错误:产物里没有 agents/*.md" >&2
  exit 1
fi
NAME="$(basename "$AGENT_FILE" .md)"

echo "→ 安装 Cursor Custom Agent: $NAME"
echo "→ 用户级目录:$DST_HOME"

# 1. agent 定义
DST_AGENT="$DST_HOME/agents/$NAME.md"
if [ -f "$DST_AGENT" ]; then
  cp "$DST_AGENT" "$DST_AGENT.bak.$TS"
  echo "  · 已备份原 agent → $DST_AGENT.bak.$TS"
fi
cp "$AGENT_FILE" "$DST_AGENT"
echo "  · agents/$NAME.md"

# 2. skills/ 装到 ~/.cursor/skills/<NAME>/
DST_SKILLS="$DST_HOME/skills/$NAME"
rm -rf "$DST_SKILLS"
mkdir -p "$DST_SKILLS"
if [ -d "$SRC/skills" ]; then
  cp -R "$SRC/skills/"* "$DST_SKILLS/" 2>/dev/null || true
  echo "  · skills/$NAME/"
fi

# 3. scripts/ 装到 ~/.cursor/scripts/<NAME>/
DST_SCRIPTS="$DST_HOME/scripts/$NAME"
if [ -d "$SRC/scripts" ]; then
  rm -rf "$DST_SCRIPTS"
  mkdir -p "$DST_SCRIPTS"
  cp -R "$SRC/scripts/"* "$DST_SCRIPTS/" 2>/dev/null || true
  echo "  · scripts/$NAME/"
fi

echo ""
echo "✓ 安装完成。"
echo ""
echo "── 下一步:首次对话 ───────────────────────────────────────────"
echo "  1. 打开 Cursor IDE(任意项目)"
echo "  2. AI 侧栏(Cmd+L)→ 选 Custom Agent → 找 $NAME"
echo "  3. 直接粘贴以下任一示例问题:"
{{- $firstEnv := "" -}}
{{- range $i, $e := .Environments -}}{{- if eq $i 0 -}}{{- $firstEnv = $e.ID -}}{{- end -}}{{- end -}}
{{- $prodEnv := $firstEnv -}}
{{- range .Environments -}}{{- if .IsProd -}}{{- $prodEnv = .ID -}}{{- end -}}{{- end }}
{{- $firstRepo := "" -}}
{{- range $i, $r := .Repos -}}{{- if eq $i 0 -}}{{- $firstRepo = $r.Name -}}{{- end -}}{{- end }}
echo "       · {{$firstEnv}} 环境 {{if $firstRepo}}{{$firstRepo}}{{else}}<service>{{end}} 接口 500 突增,帮我看下"
echo "       · {{$prodEnv}} 订单 #20250417XXX 用户说付了钱但没发货"
echo "       · {{$firstEnv}} 的 {{if $firstRepo}}{{$firstRepo}}{{else}}<service>{{end}} 为什么连不上下游?"
