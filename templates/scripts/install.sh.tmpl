        'id': agent_id,
        'name': os.environ['AGENT_NAME'],
        'model': os.environ['MODEL'],
        'workspace': os.path.expanduser('~/.openclaw/workspace/') + os.environ['WORKSPACE_NAME'],
    })
    print(f'[ok] agent {agent_id} injected')
else:
