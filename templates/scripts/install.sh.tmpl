OC_HOME="$HOME/.openclaw"
CFG="$OC_HOME/openclaw.json"
TS="$(date +%Y%m%d-%H%M%S)"

install_dep() {
  local dep="$1"
  if command -v "$dep" >/dev/null 2>&1; then
    echo "[dep] $dep already installed"
    return 0
  fi
  echo "[dep] missing: $dep, trying auto-install..."
  if command -v brew >/dev/null 2>&1; then
    case "$dep" in
      node|npx) brew install node ;;
      python3) brew install python ;;
      uvx) brew install uv ;;
      *) return 1 ;;
    esac
  elif command -v apt-get >/dev/null 2>&1; then
    sudo apt-get update
    case "$dep" in
      node|npx) sudo apt-get install -y nodejs npm ;;
      python3) sudo apt-get install -y python3 ;;
      uvx)
        curl -LsSf https://astral.sh/uv/install.sh | sh
        export PATH="$HOME/.local/bin:$PATH" ;;
      *) return 1 ;;
    esac
  else
    echo "[dep] no supported package manager found (brew/apt-get)"
    return 1
  fi
  command -v "$dep" >/dev/null 2>&1 && echo "[dep] installed: $dep" || { echo "[dep] failed to install: $dep"; return 1; }
}

install_dep python3
install_dep node
install_dep npx
install_dep uvx || true

