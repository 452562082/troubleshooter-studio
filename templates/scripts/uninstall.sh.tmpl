set -euo pipefail

WS_DIR="$HOME/.openclaw/workspace/{{.Agent.WorkspaceName}}"
TS="$(date +%Y%m%d-%H%M%S)"

if [[ -d "$WS_DIR" ]]; then
  DST="$HOME/.Trash/{{.AgentID}}-workspace-uninstall-$TS"
  mkdir -p "$DST"
  mv "$WS_DIR" "$DST/"
  echo "[ok] moved workspace to $DST"
else
  echo "[skip] workspace not found: $WS_DIR"
fi

echo "[note] openclaw.json agent entry not auto-removed"
