<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ .System.Name }} 排障机器人</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif; background: #f8fafc; height: 100vh; display: flex; flex-direction: column; }
  .header { background: #1e293b; color: white; padding: 14px 24px; font-size: 16px; font-weight: 600; display: flex; align-items: center; justify-content: space-between; }
  .header .title-line { display: flex; align-items: baseline; gap: 8px; }
  .header .sub { font-size: 12px; color: #94a3b8; font-weight: 400; }
  .header .clear-btn { background: transparent; border: 1px solid #475569; color: #cbd5e1; padding: 5px 12px; border-radius: 6px; font-size: 12px; cursor: pointer; transition: all 0.15s; }
  .header .clear-btn:hover { background: #334155; border-color: #64748b; color: #fff; }
  .header .env-selector { display: flex; align-items: center; gap: 6px; font-size: 12px; color: #cbd5e1; font-weight: 400; }
  .header .env-selector select { background: #334155; color: #e2e8f0; border: 1px solid #475569; padding: 4px 8px; border-radius: 5px; font-size: 12px; cursor: pointer; }
  .header .env-selector select:focus { outline: none; border-color: #3b82f6; }
  .header .env-selector select.is-prod { background: #7f1d1d; color: #fecaca; border-color: #991b1b; }
  .header .actions { display: flex; align-items: center; gap: 12px; }

  .messages { flex: 1; overflow-y: auto; padding: 20px 24px; }
  .msg { max-width: 80%; margin-bottom: 16px; padding: 12px 16px; border-radius: 12px; line-height: 1.65; font-size: 14px; }
  .msg.user { background: #3b82f6; color: white; margin-left: auto; border-bottom-right-radius: 4px; white-space: pre-wrap; word-break: break-word; }
  .msg.bot { background: white; color: #1e293b; border: 1px solid #e2e8f0; border-bottom-left-radius: 4px; word-break: break-word; }
  .msg.bot p { margin: 0 0 8px; }
  .msg.bot p:last-child { margin-bottom: 0; }
  .msg.bot h1, .msg.bot h2, .msg.bot h3 { margin: 12px 0 6px; font-weight: 600; }
  .msg.bot h1 { font-size: 18px; }
  .msg.bot h2 { font-size: 16px; }
  .msg.bot h3 { font-size: 14.5px; }
  .msg.bot ul, .msg.bot ol { margin: 4px 0 8px 20px; }
  .msg.bot li { margin-bottom: 2px; }
  .msg.bot code { background: #f1f5f9; padding: 1px 6px; border-radius: 4px; font-family: 'SF Mono', Consolas, monospace; font-size: 12.5px; color: #be185d; }
  .msg.bot pre { background: #1e293b; color: #e2e8f0; padding: 10px 12px; border-radius: 6px; overflow-x: auto; margin: 6px 0; position: relative; }
  .msg.bot pre code { background: transparent; color: inherit; padding: 0; font-size: 12.5px; }
  .msg.bot pre .copy-btn { position: absolute; top: 6px; right: 6px; background: #334155; color: #cbd5e1; border: none; font-size: 11px; padding: 2px 8px; border-radius: 4px; cursor: pointer; opacity: 0.7; }
  .msg.bot pre .copy-btn:hover { opacity: 1; background: #475569; }
  .msg.bot strong { font-weight: 600; }
  .msg.bot a { color: #3b82f6; text-decoration: none; }
  .msg.bot a:hover { text-decoration: underline; }
  .msg.bot .cursor { display: inline-block; width: 8px; height: 14px; background: #94a3b8; vertical-align: text-bottom; animation: blink 1s infinite; margin-left: 2px; }
  @keyframes blink { 50% { opacity: 0; } }

  .input-bar { display: flex; gap: 8px; padding: 16px 24px; background: white; border-top: 1px solid #e2e8f0; }
  .input-bar textarea { flex: 1; padding: 10px 14px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 14px; resize: none; height: 44px; font-family: inherit; }
  .input-bar textarea:focus { outline: none; border-color: #3b82f6; }
  .input-bar button { padding: 10px 20px; background: #3b82f6; color: white; border: none; border-radius: 8px; font-size: 14px; cursor: pointer; font-weight: 600; transition: background 0.15s; }
  .input-bar button:hover { background: #2563eb; }
  .input-bar button.stop { background: #ef4444; }
  .input-bar button.stop:hover { background: #dc2626; }
  .input-bar button:disabled { background: #94a3b8; cursor: not-allowed; }

  .chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
  .chip { background: #eff6ff; color: #1e40af; border: 1px solid #bfdbfe; padding: 6px 12px; border-radius: 16px; font-size: 13px; cursor: pointer; transition: background 0.15s; }
  .chip:hover { background: #dbeafe; }
</style>
</head>
<body>
<div class="header">
  <div class="title-line">
    <span>{{ .System.Name }} 排障机器人</span>
    <span class="sub">由 troubleshooter-factory 生成</span>
  </div>
  <div class="actions">
    <div class="env-selector">
      <span>默认环境:</span>
      <select id="envSelect" onchange="onEnvChange(this.value)" title="每次提问时作为默认环境注入给机器人；想临时换环境在提问里明说即可">
        <option value="">未选择</option>
        {{- range .Environments }}
        <option value="{{ .ID }}" data-prod="{{ .IsProd }}">{{ .ID }}{{ if .IsProd }} (prod){{ end }}</option>
        {{- end }}
      </select>
    </div>
    <button class="clear-btn" onclick="clearConversation()" title="清空当前对话历史（localStorage）">清空对话</button>
  </div>
</div>
<div class="messages" id="messages"></div>
<div class="input-bar">
  <textarea id="input" placeholder="描述问题... (Shift+Enter 换行，Enter 发送)" onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();onSendOrStop()}"></textarea>
  <button onclick="onSendOrStop()" id="btn">发送</button>
</div>
<script>
// ── 全局状态 ─────────────────────────────────────────────────────
const STORAGE_KEY = 'ts-standalone-chat:{{ .System.ID }}';
const ENV_KEY     = 'ts-standalone-env:{{ .System.ID }}';
let messages = [];             // {role, content} 数组，保持跟 /api/chat 约定一致
let streamCtrl = null;         // 流式期间的 AbortController；非空表示正在接收
let defaultEnv = '';           // 当前选中的默认环境 id；空串 = 未选择

// ── env selector ────────────────────────────────────────────────
function loadEnv() {
  try { return localStorage.getItem(ENV_KEY) || ''; } catch { return ''; }
}
function saveEnv(v) {
  try {
    if (v) localStorage.setItem(ENV_KEY, v);
    else   localStorage.removeItem(ENV_KEY);
  } catch {}
}
function onEnvChange(v) {
  defaultEnv = v;
  saveEnv(v);
  applyEnvStyling();
}
function applyEnvStyling() {
  const sel = document.getElementById('envSelect');
  const opt = sel.selectedOptions[0];
  const isProd = opt && opt.dataset.prod === 'true';
  sel.classList.toggle('is-prod', !!isProd);
}

// ── localStorage 持久化 ─────────────────────────────────────────
function saveMessages() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(messages)); } catch {}
}
function loadMessages() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? JSON.parse(raw) : [];
  } catch { return []; }
}

function clearConversation() {
  if (streamCtrl) { streamCtrl.abort(); streamCtrl = null; }
  if (messages.length === 0) return;
  if (!confirm('清空当前对话历史？（localStorage 里的会被删除，不可恢复）')) return;
  messages = [];
  try { localStorage.removeItem(STORAGE_KEY); } catch {}
  renderAll();
}

// ── 气泡渲染 ────────────────────────────────────────────────────
function renderAll() {
  const box = document.getElementById('messages');
  box.innerHTML = '';
  if (messages.length === 0) {
    box.appendChild(renderWelcome());
  } else {
    for (const m of messages) {
      box.appendChild(renderMsg(m.role === 'assistant' ? 'bot' : 'user', m.content));
    }
  }
  box.scrollTop = box.scrollHeight;
}

function renderWelcome() {
  const div = document.createElement('div');
  div.className = 'msg bot';
  div.textContent = '你好，我是 {{ .System.Name }} 排障机器人。请描述你遇到的问题，包括：环境（dev/prod）、服务名、错误现象。';
  const chips = document.createElement('div');
  chips.className = 'chips';
  chips.innerHTML = [
    {{- $firstEnv := "" -}}
    {{- range $i, $e := .Environments -}}{{- if eq $i 0 -}}{{- $firstEnv = $e.ID -}}{{- end -}}{{- end -}}
    {{- $prodEnv := $firstEnv -}}
    {{- range .Environments -}}{{- if .IsProd -}}{{- $prodEnv = .ID -}}{{- end -}}{{- end -}}
    {{- $firstRepo := "" -}}
    {{- range $i, $r := .Repos -}}{{- if eq $i 0 -}}{{- $firstRepo = $r.Name -}}{{- end -}}{{- end }}
    `<span class="chip">{{$firstEnv}} 环境 {{if $firstRepo}}{{$firstRepo}}{{else}}&lt;service&gt;{{end}} 接口 500 突增，帮我看下</span>`,
    `<span class="chip">{{$prodEnv}} 订单 #20250417XXX 用户说付了钱但没发货</span>`,
    `<span class="chip">查一下 {{$prodEnv}} 配置里 &lt;key&gt; 是什么值，最近改过吗</span>`,
    `<span class="chip">{{$firstEnv}} 的 {{if $firstRepo}}{{$firstRepo}}{{else}}&lt;service&gt;{{end}} 为什么连不上下游</span>`,
  ].join('');
  chips.querySelectorAll('.chip').forEach(c => c.addEventListener('click', () => {
    const input = document.getElementById('input');
    input.value = c.textContent.trim();
    input.focus();
  }));
  div.appendChild(chips);
  return div;
}

// renderMsg 根据 role 渲染一条消息；user 明文，bot 走 markdown
function renderMsg(role, content) {
  const div = document.createElement('div');
  div.className = 'msg ' + role;
  if (role === 'bot') {
    div.innerHTML = renderMarkdown(content);
    attachCopyButtons(div);
  } else {
    div.textContent = content;
  }
  return div;
}

function attachCopyButtons(scope) {
  scope.querySelectorAll('pre').forEach(pre => {
    if (pre.querySelector('.copy-btn')) return;
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = '复制';
    btn.addEventListener('click', () => {
      const code = pre.querySelector('code');
      if (!code) return;
      navigator.clipboard.writeText(code.textContent).then(() => {
        btn.textContent = '已复制';
        setTimeout(() => { btn.textContent = '复制'; }, 1400);
      });
    });
    pre.appendChild(btn);
  });
}

// ── 最小 Markdown 渲染（code fence / inline code / headings / list / bold / link / paragraphs） ──
function escapeHTML(s) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}
function renderMarkdown(src) {
  if (!src) return '';
  const placeholders = [];
  // 1) 三反引号代码块先占位，避免内部内容被其它规则误伤
  src = src.replace(/```([a-zA-Z0-9_+-]*)\n?([\s\S]*?)```/g, (_m, lang, code) => {
    const i = placeholders.length;
    placeholders.push(`<pre><code${lang ? ` class="lang-${escapeHTML(lang)}"` : ''}>${escapeHTML(code.replace(/\n$/, ''))}</code></pre>`);
    return `\u0000CB${i}\u0000`;
  });
  // 2) 剩余内容 HTML 转义
  src = escapeHTML(src);
  // 3) inline code
  src = src.replace(/`([^`\n]+)`/g, (_m, c) => `<code>${c}</code>`);
  // 4) bold
  src = src.replace(/\*\*([^*\n]+)\*\*/g, '<strong>$1</strong>');
  // 5) links [text](url)
  src = src.replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
  // 6) 按行处理 headings / list / paragraph
  const lines = src.split('\n');
  const out = [];
  let listKind = null; // 'ul' | 'ol' | null
  let paraBuf = [];
  const flushPara = () => {
    if (paraBuf.length) {
      out.push('<p>' + paraBuf.join('<br/>') + '</p>');
      paraBuf = [];
    }
  };
  const flushList = () => {
    if (listKind) { out.push(`</${listKind}>`); listKind = null; }
  };
  for (let ln of lines) {
    if (ln.startsWith('\u0000CB')) { flushPara(); flushList(); out.push(ln); continue; }
    const h = ln.match(/^(#{1,3})\s+(.*)$/);
    if (h) { flushPara(); flushList(); const lvl = h[1].length; out.push(`<h${lvl}>${h[2]}</h${lvl}>`); continue; }
    const ul = ln.match(/^[\-*]\s+(.*)$/);
    const ol = ln.match(/^(\d+)\.\s+(.*)$/);
    if (ul) { flushPara(); if (listKind !== 'ul') { flushList(); out.push('<ul>'); listKind = 'ul'; } out.push(`<li>${ul[1]}</li>`); continue; }
    if (ol) { flushPara(); if (listKind !== 'ol') { flushList(); out.push('<ol>'); listKind = 'ol'; } out.push(`<li>${ol[2]}</li>`); continue; }
    if (ln.trim() === '') { flushPara(); flushList(); continue; }
    paraBuf.push(ln);
  }
  flushPara();
  flushList();
  let html = out.join('\n');
  // 7) 还原代码块占位
  html = html.replace(/\u0000CB(\d+)\u0000/g, (_m, i) => placeholders[+i] || '');
  return html;
}

// ── 发送 / 停止 ──────────────────────────────────────────────────
function onSendOrStop() {
  if (streamCtrl) {
    streamCtrl.abort();
    streamCtrl = null;
    return;
  }
  send();
}

function setBtnState(mode) {
  const btn = document.getElementById('btn');
  if (mode === 'stream') {
    btn.textContent = '停止';
    btn.classList.add('stop');
    btn.disabled = false;
  } else {
    btn.textContent = '发送';
    btn.classList.remove('stop');
    btn.disabled = false;
  }
}

async function send() {
  const input = document.getElementById('input');
  const text = input.value.trim();
  if (!text) return;
  input.value = '';

  messages.push({role: 'user', content: text});
  const box = document.getElementById('messages');
  // 首次发送时清掉 welcome 气泡
  if (messages.length === 1) box.innerHTML = '';
  box.appendChild(renderMsg('user', text));

  const botDiv = document.createElement('div');
  botDiv.className = 'msg bot';
  const cursor = document.createElement('span');
  cursor.className = 'cursor';
  botDiv.appendChild(cursor);
  box.appendChild(botDiv);
  box.scrollTop = box.scrollHeight;

  let collected = '';
  streamCtrl = new AbortController();
  setBtnState('stream');

  const rerender = () => {
    botDiv.innerHTML = renderMarkdown(collected);
    attachCopyButtons(botDiv);
    // 流式期间在尾部追加光标提示
    if (streamCtrl) {
      const c = document.createElement('span');
      c.className = 'cursor';
      botDiv.appendChild(c);
    }
    box.scrollTop = box.scrollHeight;
  };

  try {
    const headers = {'Content-Type': 'application/json', 'Accept': 'text/event-stream'};
    if (defaultEnv) headers['X-Default-Env'] = defaultEnv;
    const resp = await fetch('/api/chat', {
      method: 'POST',
      headers,
      body: JSON.stringify({messages}),
      signal: streamCtrl.signal,
    });
    if (!resp.ok || !resp.body) {
      let err = 'HTTP ' + resp.status;
      try { const j = await resp.json(); if (j.error) err = j.error; } catch {}
      collected = '❌ ' + err;
      rerender();
    } else {
      const reader = resp.body.getReader();
      const decoder = new TextDecoder();
      let buf = '';
      outer: while (true) {
        const {done, value} = await reader.read();
        if (done) break;
        buf += decoder.decode(value, {stream: true});
        const events = buf.split('\n\n');
        buf = events.pop() || '';
        for (const ev of events) {
          const line = ev.trim();
          if (!line.startsWith('data:')) continue;
          let payload;
          try { payload = JSON.parse(line.slice(5).trim()); } catch { continue; }
          if (payload.error) {
            collected = '❌ ' + payload.error;
            rerender();
            break outer;
          }
          if (payload.delta) {
            collected += payload.delta;
            rerender();
          }
          if (payload.done) break outer;
        }
      }
    }
  } catch (e) {
    if (e.name === 'AbortError') {
      collected += '\n\n_[已停止]_';
    } else {
      collected = '❌ 请求失败：' + e.message;
    }
  } finally {
    streamCtrl = null;
    setBtnState('send');
    // 最终渲染（移除光标）
    botDiv.innerHTML = renderMarkdown(collected);
    attachCopyButtons(botDiv);
    if (collected) {
      messages.push({role: 'assistant', content: collected});
      saveMessages();
    } else {
      // 空回复把 bot 气泡移除
      box.removeChild(botDiv);
    }
  }
}

// ── 初始化 ──────────────────────────────────────────────────────
messages = loadMessages();
renderAll();

defaultEnv = loadEnv();
const envSel = document.getElementById('envSelect');
if (defaultEnv) {
  // 若 localStorage 里的 env 已经不在当前下拉选项里（system.yaml 改过），静默清掉
  const match = Array.from(envSel.options).find(o => o.value === defaultEnv);
  if (match) envSel.value = defaultEnv;
  else { defaultEnv = ''; saveEnv(''); }
}
applyEnvStyling();
</script>
</body>
</html>
