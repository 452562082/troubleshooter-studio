# config-map.yaml
# 由 troubleshooter-studio 生成。多源配置:每个服务按 repos[].config_source 路由到对应源。
# - status: verified → 来自代码分析或上轮人工沉淀
# - status: inferred → 骨架,需人工校对后改为 verified
# - runtime 字段:所有配置中心都通过 HTTP 脚本访问,LLM 看到 runtime 标记直接调 config-executor SKILL
#   下的对应脚本,不需要找 mcp_server。当前 4 个 runtime 值:
#     nacos-http   → scripts/nacos_config.py(2026-05-15 方案 B,token 改不了,每次脚本自己 login 即用即弃)
#     apollo-http  → scripts/apollo_config.py(生态暂无稳定 Apollo MCP)
#     consul-http  → scripts/consul_config.py(同上)
#     kuboard-http → scripts/resolve_runtime_k8s.py(kuboard 历来走 HTTP)
# - 凭据来源:
#     nacos:  <workspace>/scripts/.env(CC_ADDR_<ENV> / CC_USER_<ENV> / CC_PASS_<ENV>)
#             LLM 调脚本前必须先 `source scripts/.env`
#     apollo / consul / kuboard:  ~/.openclaw/<agent-id>-creds.json(脚本按 --agent-id --env 自己取)
# 优先级:analyzer finding > prior manual override > inferred skeleton
{{- $ctx := .}}
{{- $primaryCC := .Infrastructure.PrimaryConfigCenter.Type}}
config_center: {{$primaryCC}}        # 主源类型;多源场景下其它源的 type 在 sources 块下展示
{{- if gt (len .Infrastructure.ConfigCenters) 1}}
sources:                           # 多源声明;每个 service 按下面 config_source 引用对应源
{{- range .Infrastructure.ConfigCenters}}
  - id: {{.ID | printf "%q"}}
    type: {{.Type | printf "%q"}}
{{- end}}
{{- end}}
environments:
{{- range .Environments}}
  {{.ID}}:
    {{- $envID := .ID}}
    {{- range $.Repos}}
      {{- $repo := .}}
      {{- $serviceNames := .ServiceNames}}
      {{- if not $serviceNames}}{{$serviceNames = list .Name}}{{end}}
      {{- range $serviceNames}}
        {{- $svc := .}}
        {{- $sourceID := repoConfigSource $ctx $svc}}
        {{- $src := configSourceByID $ctx $sourceID}}
        {{- $cc := $src.Type}}
        {{- $patterns := $src.DataIDPatterns}}
        {{- $endpoints := $src.Endpoints}}
        {{- $nsHint := ""}}
        {{- range $endpoints}}{{if eq .Env $envID}}{{$nsHint = .NamespaceHint}}{{end}}{{end}}
        {{- $f := findConfig $ctx $svc $envID}}
        {{- $p := findPrior $ctx $svc $envID}}
      {{$svc}}:
        {{- if ne $sourceID "default"}}
        config_source: {{$sourceID | printf "%q"}}        # 多源:本服务走副源
        {{- end}}
        {{- if eq $cc "nacos"}}
        {{- if $f}}
        namespaceId: {{if $f.NamespaceID}}{{$f.NamespaceID | printf "%q"}}{{else}}{{$nsHint | printf "%q"}}{{end}}
        group: {{if $f.Group}}{{$f.Group | printf "%q"}}{{else}}"DEFAULT_GROUP"{{end}}
        dataId: {{$f.DataID | printf "%q"}}
        runtime: nacos-http
        status: verified
        source: {{$f.SourceFile | printf "%q"}}
        {{- else if $p}}
        namespaceId: {{$p.NamespaceID | printf "%q"}}
        group: {{if $p.Group}}{{$p.Group | printf "%q"}}{{else}}"DEFAULT_GROUP"{{end}}
        dataId: {{$p.DataID | printf "%q"}}
        runtime: nacos-http
        status: verified
        {{- else}}
        namespaceId: {{$nsHint | printf "%q"}}
        group: "DEFAULT_GROUP"
        dataId: {{if $patterns}}{{index $patterns 0 | printf "%q"}}{{else}}""{{end}}
        runtime: nacos-http
        status: inferred
        {{- end}}
        {{- else if eq $cc "apollo"}}
        {{- if $f}}
        appId: {{if $f.AppID}}{{$f.AppID | printf "%q"}}{{else}}{{$svc | printf "%q"}}{{end}}
        cluster: {{if $f.Cluster}}{{$f.Cluster | printf "%q"}}{{else}}"default"{{end}}
        namespaces:
        {{- if $f.Namespaces}}
          {{- range $f.Namespaces}}
          - {{. | printf "%q"}}
          {{- end}}
        {{- else}}
          - "application"
        {{- end}}
        {{- if $f.ServerAddr}}
        meta: {{$f.ServerAddr | printf "%q"}}
        {{- end}}
        runtime: {{printf "%s-http" $cc}}
        status: verified
        source: {{$f.SourceFile | printf "%q"}}
        {{- else if $p}}
        appId: {{if $p.AppID}}{{$p.AppID | printf "%q"}}{{else}}{{$svc | printf "%q"}}{{end}}
        cluster: {{if $p.Cluster}}{{$p.Cluster | printf "%q"}}{{else}}"default"{{end}}
        namespaces:
        {{- if $p.Namespaces}}
          {{- range $p.Namespaces}}
          - {{. | printf "%q"}}
          {{- end}}
        {{- else}}
          - "application"
        {{- end}}
        {{- if $p.ServerAddr}}
        meta: {{$p.ServerAddr | printf "%q"}}
        {{- end}}
        runtime: {{printf "%s-http" $cc}}
        status: verified
        {{- else}}
        appId: {{$svc | printf "%q"}}
        cluster: "default"
        namespaces:
          - "application"
        runtime: {{printf "%s-http" $cc}}
        status: inferred
        {{- end}}
        {{- else if eq $cc "kuboard"}}
        # kuboard:**不通过 MCP**,走 Kuboard HTTP API + scripts/resolve_runtime_k8s.py 直读。
        # 凭证(URL/access_key/cluster/namespace/configmap)按 agent_id 索引,优先级:
        #   1. ~/.openclaw/<agent_id>-creds.json     (OpenClaw 部署专用)
        #   2. ~/.tshoot/<agent_id>-creds.json       (Claude Code/Cursor/Codex 通用)
        # agent 看到 runtime: kuboard-http 就 **不要** 尝试找 mcp_server,直接用脚本调 HTTP。
        configmap_key: {{$svc | printf "%q"}}
        runtime: kuboard-http
        status: inferred
        {{- else if eq $cc "consul"}}
        {{- if $f}}
        kv_prefix: {{if $f.KVPrefix}}{{$f.KVPrefix | printf "%q"}}{{else}}"config"{{end}}
        default_context: {{if $f.DefaultContext}}{{$f.DefaultContext | printf "%q"}}{{else}}{{$svc | printf "%q"}}{{end}}
        {{- if $f.ServerAddr}}
        host: {{$f.ServerAddr | printf "%q"}}
        {{- end}}
        runtime: {{printf "%s-http" $cc}}
        status: verified
        source: {{$f.SourceFile | printf "%q"}}
        {{- else if $p}}
        kv_prefix: {{if $p.KVPrefix}}{{$p.KVPrefix | printf "%q"}}{{else}}"config"{{end}}
        default_context: {{if $p.DefaultContext}}{{$p.DefaultContext | printf "%q"}}{{else}}{{$svc | printf "%q"}}{{end}}
        {{- if $p.ServerAddr}}
        host: {{$p.ServerAddr | printf "%q"}}
        {{- end}}
        runtime: {{printf "%s-http" $cc}}
        status: verified
        {{- else}}
        kv_prefix: "config"
        default_context: {{$svc | printf "%q"}}
        runtime: {{printf "%s-http" $cc}}
        status: inferred
        {{- end}}
        {{- else}}
        status: unsupported_config_center
        {{- end}}
      {{- end}}
    {{- end}}
{{- end}}
